# Copie ce fichier en .env.publish et remplis les tokens.
# .env.publish est dans .gitignore — ne le commite jamais.

# VS Code Marketplace (Azure DevOps)
# Créer sur : https://dev.azure.com → Settings → Personal access tokens
# Scope requis : Marketplace → Manage
VSCE_PAT=ton_pat_azure_devops_ici

# Open VSX (Cursor, VSCodium, Gitpod…)
# Créer sur : https://open-vsx.org → ton profil → Access Tokens
OVSX_PAT=ton_pat_openvsx_ici
