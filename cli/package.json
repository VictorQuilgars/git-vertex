{
  "name": "git-vertex-cli",
  "version": "0.1.0",
  "description": "Git Vertex — terminal UI (TUI) Git client. Commit graph, staging, branches, all from the keyboard.",
  "type": "module",
  "bin": {
    "gv": "./bin/gv.mjs"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "dev": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  }
}
